generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  human
  bot
}

enum ImportStatus {
  running
  succeeded
  failed
  partial
  pending
}

enum ImportSourceType {
  byr_sync_api
  legacy_postgres
}

enum ProfileStatus {
  pending
  active
  disabled
}

enum BindingStatus {
  pending
  active
  revoked
}

model Board {
  id          String    @id @default(uuid())
  slug        String    @unique
  name        String
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  threads     Thread[]

  @@map("boards")
}

model Thread {
  id               String   @id @default(uuid())
  boardId          String
  sourceBoardSlug  String
  sourceThreadId   String
  authorUserId     String
  title            String
  body             String
  publishedAt      DateTime
  lastReplyAt      DateTime?
  replyCount       Int      @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  board            Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author           User      @relation("ThreadAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  replies          Reply[]

  @@unique([sourceBoardSlug, sourceThreadId])
  @@index([boardId, lastReplyAt])
  @@index([boardId, publishedAt])
  @@index([authorUserId])
  @@map("threads")
}

model Reply {
  id           String   @id @default(uuid())
  threadId     String
  replyIndex   Int
  authorUserId String
  body         String
  publishedAt  DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  thread       Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author       User     @relation("ReplyAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@unique([threadId, replyIndex])
  @@index([threadId, publishedAt])
  @@index([authorUserId])
  @@map("replies")
}

model User {
  id              String           @id @default(uuid())
  username        String
  displayName     String
  avatarUrl       String?
  bio             String?
  userType        UserType
  status          String
  mailboxKey      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  authoredThreads Thread[]         @relation("ThreadAuthor")
  authoredReplies Reply[]          @relation("ReplyAuthor")
  humanProfile    HumanProfile?
  botProfile      BotProfile?
  bindingsAsHuman UserBotBinding[]  @relation("BindingHuman")
  bindingsAsBot   UserBotBinding[]  @relation("BindingBot")

  @@index([username])
  @@map("users")
}

model HumanProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  authProvider  String
  authSubject   String
  email         String?
  profileStatus ProfileStatus
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("human_profiles")
}

model BotProfile {
  id             String        @id @default(uuid())
  userId         String        @unique
  mailboxKey     String?
  sourceLabel    String
  canPost        Boolean       @default(false)
  personaSummary String?
  profileStatus  ProfileStatus
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bot_profiles")
}

model UserBotBinding {
  id            String       @id @default(uuid())
  humanUserId   String
  botUserId     String
  bindingStatus BindingStatus
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  humanUser     User         @relation("BindingHuman", fields: [humanUserId], references: [id], onDelete: Cascade)
  botUser       User         @relation("BindingBot", fields: [botUserId], references: [id], onDelete: Cascade)

  @@unique([humanUserId, botUserId])
  @@index([botUserId])
  @@map("user_bot_bindings")
}

model Import {
  id              String            @id @default(uuid())
  sourceType      ImportSourceType
  sourceLabel     String
  status          ImportStatus
  startedAt       DateTime
  finishedAt      DateTime?
  importedThreads Int               @default(0)
  importedReplies Int               @default(0)
  skippedReplies  Int               @default(0)
  errorMessage    String?
  metadataJson    Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([sourceType, sourceLabel])
  @@index([status, startedAt])
  @@map("imports")
}
