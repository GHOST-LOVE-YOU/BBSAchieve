generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  human
  bot
}

enum ImportStatus {
  pending
  running
  succeeded
  failed
}

enum ImportSourceType {
  byr
  manual
}

model Board {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  description String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  threads     Thread[]

  @@map("boards")
}

model Thread {
  id                 String    @id @default(cuid())
  boardId            String
  sourceBoardSlug    String
  sourceThreadId     String
  authorUserId       String
  title              String
  body               String
  publishedAt        DateTime
  lastReplyAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  board              Board     @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author             User      @relation("ThreadAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  replies            Reply[]

  @@unique([sourceBoardSlug, sourceThreadId])
  @@index([boardId, lastReplyAt])
  @@index([boardId, publishedAt])
  @@index([authorUserId])
  @@map("threads")
}

model Reply {
  id           String    @id @default(cuid())
  threadId     String
  replyIndex   Int
  authorUserId String
  body         String
  publishedAt  DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  thread       Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author       User      @relation("ReplyAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@unique([threadId, replyIndex])
  @@index([threadId, publishedAt])
  @@index([authorUserId])
  @@map("replies")
}

model User {
  id                String          @id @default(cuid())
  username          String
  displayName       String
  userType          UserType
  status            String
  mailboxKey        String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  authoredThreads   Thread[]        @relation("ThreadAuthor")
  authoredReplies   Reply[]         @relation("ReplyAuthor")
  humanProfile      HumanProfile?
  botProfile        BotProfile?
  bindingsAsUser    UserBotBinding[] @relation("BindingUser")
  bindingsAsBot     UserBotBinding[] @relation("BindingBot")

  @@index([username])
  @@map("users")
}

model HumanProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("human_profiles")
}

model BotProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bot_profiles")
}

model UserBotBinding {
  id           String   @id @default(cuid())
  userId       String
  botUserId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation("BindingUser", fields: [userId], references: [id], onDelete: Cascade)
  bot          User     @relation("BindingBot", fields: [botUserId], references: [id], onDelete: Cascade)

  @@unique([userId, botUserId])
  @@index([botUserId])
  @@map("user_bot_bindings")
}

model Import {
  id               String          @id @default(cuid())
  sourceType       ImportSourceType
  sourceLabel      String
  status           ImportStatus
  startedAt        DateTime
  finishedAt       DateTime?
  importedThreads  Int             @default(0)
  importedReplies  Int             @default(0)
  skippedReplies   Int             @default(0)
  errorMessage     String?
  metadataJson     Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([sourceType, sourceLabel])
  @@index([status, startedAt])
  @@map("imports")
}
