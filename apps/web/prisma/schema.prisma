generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  human
  bot
}

enum ImportStatus {
  running
  succeeded
  failed
  partial
  pending
}

enum ImportJobStatus {
  pending
  running
  paused
  failed
  succeeded
  cancelled
}

enum ImportSourceType {
  byr_sync_api
  legacy_postgres
}

enum ScheduledTaskRunStatus {
  running
  succeeded
  failed
  skipped
}

enum ScheduledTaskTriggerSource {
  scheduled
  manual
}

enum ProfileStatus {
  pending
  active
  disabled
}

enum SubscriptionTargetType {
  thread
  reply
}

enum SubscriptionStatus {
  active
  muted
  revoked
}

enum NotificationType {
  thread_reply
  reply_quote
  mirror_source_stale
  bot_rotated
  system
}

model Board {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  threads     Thread[]

  @@map("boards")
}

model Thread {
  id              String                @id @default(uuid())
  boardId         String
  sourceBoardSlug String
  sourceThreadId  String
  authorUserId    String
  title           String
  body            String
  publishedAt     DateTime
  lastReplyAt     DateTime?
  replyCount      Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  board           Board                 @relation(fields: [boardId], references: [id], onDelete: Cascade)
  author          User                  @relation("ThreadAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  replies         Reply[]
  subscriptions   ContentSubscription[] @relation("ThreadSubscriptions")
  notifications   Notification[]        @relation("ThreadNotifications")
  bookmarks       ThreadBookmark[]      @relation("ThreadBookmarks")

  @@unique([sourceBoardSlug, sourceThreadId])
  @@index([boardId, lastReplyAt])
  @@index([boardId, publishedAt])
  @@index([authorUserId])
  @@map("threads")
}

model Reply {
  id            String                @id @default(uuid())
  threadId      String
  replyIndex    Int
  authorUserId  String
  body          String
  publishedAt   DateTime
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  thread        Thread                @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author        User                  @relation("ReplyAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)
  subscriptions ContentSubscription[] @relation("ReplySubscriptions")
  notifications Notification[]        @relation("ReplyNotifications")

  @@unique([threadId, replyIndex])
  @@index([threadId, publishedAt])
  @@index([authorUserId])
  @@map("replies")
}

model User {
  id                   String                @id @default(uuid())
  username             String
  displayName          String
  avatarUrl            String?
  bio                  String?
  userType             UserType
  status               String
  mailboxKey           String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  authoredThreads      Thread[]              @relation("ThreadAuthor")
  authoredReplies      Reply[]               @relation("ReplyAuthor")
  humanProfile         HumanProfile?
  botProfile           BotProfile?
  contentSubscriptions ContentSubscription[] @relation("HumanContentSubscriptions")
  notifications        Notification[]        @relation("RecipientNotifications")
  bookmarks            ThreadBookmark[]      @relation("UserBookmarks")

  @@index([username])
  @@map("users")
}

model HumanProfile {
  id            String        @id @default(uuid())
  userId        String        @unique
  authProvider  String
  authSubject   String
  email         String?
  profileStatus ProfileStatus
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([authProvider, authSubject])
  @@map("human_profiles")
}

model BotProfile {
  id               String        @id @default(uuid())
  userId           String        @unique
  mailboxKey       String?
  sourceLabel      String
  /// Optional comma-separated hint set of upstream usernames this bot mirrors.
  /// The product brief notes a single bot can map to multiple source-site
  /// users, so this is purely advisory metadata for admins/UI.
  sourceUserHints  String?
  canPost          Boolean       @default(false)
  personaSummary   String?
  profileStatus    ProfileStatus
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bot_profiles")
}

model ContentSubscription {
  id                 String                 @id @default(uuid())
  humanUserId        String
  targetType         SubscriptionTargetType
  threadId           String?
  replyId            String?
  subscriptionStatus SubscriptionStatus     @default(active)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  humanUser          User                   @relation("HumanContentSubscriptions", fields: [humanUserId], references: [id], onDelete: Cascade)
  thread             Thread?                @relation("ThreadSubscriptions", fields: [threadId], references: [id], onDelete: Cascade)
  reply              Reply?                 @relation("ReplySubscriptions", fields: [replyId], references: [id], onDelete: Cascade)
  notifications      Notification[]         @relation("SubscriptionNotifications")

  @@unique([humanUserId, targetType, threadId])
  @@unique([humanUserId, targetType, replyId])
  @@index([humanUserId, subscriptionStatus])
  @@index([targetType, threadId])
  @@index([targetType, replyId])
  @@map("content_subscriptions")
}

model Notification {
  id              String              @id @default(uuid())
  recipientUserId String
  type            NotificationType
  /// Optional subscription that fanned out this notification — used to
  /// support "unsubscribe from this notification's source" affordances and to
  /// short-circuit notifications when a subscription is later revoked.
  subscriptionId  String?
  threadId        String?
  replyId         String?
  /// User-facing summary text. Keeping it denormalized lets us render notif
  /// rows without rejoining onto Thread/Reply rows that may have been pruned
  /// after the upstream source was deleted.
  body            String
  /// Short pseudo-anonymous label for who/what triggered this notification.
  /// E.g. "@镜像收件箱 mirror-flower@today" or "@电子荒野旅人 在 12 楼回复".
  sourceLabel     String?
  /// Optional ISO time string from the upstream event ("镜像同步于 1 小时前").
  occurredAt      DateTime            @default(now())
  readAt          DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  recipient       User                 @relation("RecipientNotifications", fields: [recipientUserId], references: [id], onDelete: Cascade)
  subscription    ContentSubscription? @relation("SubscriptionNotifications", fields: [subscriptionId], references: [id], onDelete: SetNull)
  thread          Thread?              @relation("ThreadNotifications", fields: [threadId], references: [id], onDelete: SetNull)
  reply           Reply?               @relation("ReplyNotifications", fields: [replyId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, readAt])
  @@index([recipientUserId, occurredAt])
  @@index([type, occurredAt])
  @@map("notifications")
}

model ThreadBookmark {
  id          String   @id @default(uuid())
  humanUserId String
  threadId    String
  createdAt   DateTime @default(now())
  humanUser   User     @relation("UserBookmarks", fields: [humanUserId], references: [id], onDelete: Cascade)
  thread      Thread   @relation("ThreadBookmarks", fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([humanUserId, threadId])
  @@index([humanUserId, createdAt])
  @@map("thread_bookmarks")
}

model Import {
  id              String           @id @default(uuid())
  sourceType      ImportSourceType
  sourceLabel     String
  status          ImportStatus
  startedAt       DateTime
  finishedAt      DateTime?
  importedThreads Int              @default(0)
  importedReplies Int              @default(0)
  skippedReplies  Int              @default(0)
  errorMessage    String?
  metadataJson    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([sourceType, sourceLabel])
  @@index([status, startedAt])
  @@map("imports")
}

model ImportJob {
  id               String           @id @default(uuid())
  jobType          String
  sourceType       ImportSourceType
  sourceLabel      String
  status           ImportJobStatus  @default(pending)
  cursorThreadKey  String?
  lastProcessedAt  DateTime?
  startedAt        DateTime?
  finishedAt       DateTime?
  processedThreads Int              @default(0)
  processedReplies Int              @default(0)
  skippedThreads   Int              @default(0)
  skippedReplies   Int              @default(0)
  errorMessage     String?
  progressNote     String?
  metadataJson     Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([sourceType, sourceLabel])
  @@index([status, startedAt])
  @@map("import_jobs")
}

model ScheduledTaskRun {
  id              String                     @id @default(uuid())
  taskKey         String
  taskTitle       String
  triggerSource   ScheduledTaskTriggerSource
  status          ScheduledTaskRunStatus
  startedAt       DateTime
  finishedAt      DateTime?
  durationMs      Int?
  intervalMinutes Int
  windowMinutes   Int
  boardName       String
  importedThreads Int                        @default(0)
  importedReplies Int                        @default(0)
  skippedReason   String?
  errorMessage    String?
  metadataJson    Json?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  @@index([taskKey, startedAt])
  @@index([status, startedAt])
  @@map("scheduled_task_runs")
}
